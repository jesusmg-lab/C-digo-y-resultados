Cell[CellGroupData[{

Cell["Instrucciones para el uso del c\[OAcute]digo ", "Section",
 CellChangeTimes->{{3.942366359297312*^9, 
  3.9423663969404545`*^9}},ExpressionUUID->"548100e3-8a0f-4742-8a7e-\
b7ab4d0491a1"],

Cell["\<\
1. Correr toda la secci\[OAcute]n \[OpenCurlyDoubleQuote]Par\[AAcute]metros \
para xCoba\[CloseCurlyDoubleQuote]
2. Escoger la m\[EAcute]trica que se requiera (\[UAcute]nicamente correr la m\
\[EAcute]trica escogida, no toda la secci\[OAcute]n)
3. Correr toda la secci\[OAcute]n \[OpenCurlyDoubleQuote]Variaci\[OAcute]n de \
la acci\[OAcute]n\[CloseCurlyDoubleQuote]
4. Correr toda la secci\[OAcute]n \[OpenCurlyDoubleQuote]Resultados\
\[CloseCurlyDoubleQuote]
Y as\[IAcute] obtendr\[AAcute]n la ecuaci\[OAcute]n de campo bajo la m\
\[EAcute]trica escogida en el punto 2 \
\>", "Text",
 CellChangeTimes->{{3.942366383581465*^9, 3.942366421049707*^9}, {
  3.942366499517809*^9, 
  3.9423666737810745`*^9}},ExpressionUUID->"a323ed87-18c1-5549-948e-\
8250d73b548c"]
}, Closed]],

