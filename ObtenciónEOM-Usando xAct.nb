   3.9844959453827744`*^9}},ExpressionUUID->"bde46abe-da3a-1e45-b9b0-\
34636e2f57c8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SetCMetric", "[", 
    RowBox[{"G", ",", "base", ",", 
     RowBox[{"SignatureOfMetric", "->", 
      RowBox[{"{", 
       RowBox[{"3", ",", "1", ",", "0"}], "}"}]}]}], "]"}], ";"}], 
