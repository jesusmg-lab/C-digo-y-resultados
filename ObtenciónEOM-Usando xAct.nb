  3.94236436878068*^9}},ExpressionUUID->"26a7a531-37e2-f54f-a940-\
72bee8176994"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"G", "=", 
     RowBox[{"CTensor", "[", 
      RowBox[{
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"A", "[", 
           RowBox[{
            RowBox[{"t", "[", "]"}], ",", 
            RowBox[{"r", "[", "]"}], ",", 
            RowBox[{"\[Theta]", "[", "]"}], ",", 
            RowBox[{"\[Phi]", "[", "]"}]}], "]"}], ",", 
          RowBox[{"B", "[", 
           RowBox[{
            RowBox[{"t", "[", "]"}], ",", 
            RowBox[{"r", "[", "]"}], ",", 
            RowBox[{"\[Theta]", "[", "]"}], ",", 
            RowBox[{"\[Phi]", "[", "]"}]}], "]"}], ",", 
          RowBox[{"C", "[", 
           RowBox[{
            RowBox[{"t", "[", "]"}], ",", 
            RowBox[{"r", "[", "]"}], ",", 
            RowBox[{"\[Theta]", "[", "]"}], ",", 
            RowBox[{"\[Phi]", "[", "]"}]}], "]"}], ",", 
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"t", "[", "]"}], ",", 
            RowBox[{"r", "[", "]"}], ",", 
            RowBox[{"\[Theta]", "[", "]"}], ",", 
            RowBox[{"\[Phi]", "[", "]"}]}], "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "base"}], ",", 
         RowBox[{"-", "base"}]}], "}"}]}], "]"}]}], ";"}], "*)"}], 
  "\[IndentingNewLine]"}]], "Input",
 CellChangeTimes->{{3.942364370050556*^9, 3.94236450887891*^9}},
 CellLabel->"In[33]:=",ExpressionUUID->"650db55c-c8bd-8c40-ac01-30b0225fb505"],

Cell["\<\
Donde A, B, C y D deber\[AAcute]n estar definidos en la secci\[OAcute]n de \
\[OpenCurlyDoubleQuote]Par\[AAcute]metros de xCoba\[CloseCurlyDoubleQuote] y \
deben de depender de las coordenadas definidas sobre la variedad, en nuestro \
caso usamos [t[],r[],\[Theta][],\[Phi][]], n\[OAcute]tese que todas las \
variables est\[AAcute]n con corchete, es importante que se lo coloquen.
Lo que se hace espec\[IAcute]ficamente, es definir un tensor G diagonal, con \
componentes A, B, C y D para (0, 0), (1,1), (2,2), (3,3), respectivamente, y \
la parte final indica donde se encuentran los indices, si se usa un \
\[CloseCurlyDoubleQuote]-\[OpenCurlyDoubleQuote] (menos) es porque es un \
indice abajo (en caso contrario, tiene indice arriba)\
\>", "Text",
 CellChangeTimes->{{3.9423645153438663`*^9, 3.9423646842883797`*^9}, {
  3.942364780188265*^9, 
  3.942364879843193*^9}},ExpressionUUID->"91bc176a-ff8a-584b-ab07-\
1e6ca17da9c9"]
}, Closed]]
}, Closed]],

