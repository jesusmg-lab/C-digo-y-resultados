0be990dbf9c9"],

Cell[TextData[{
 "\n",
 StyleBox["Es una automatizaci\[OAcute]n de elecci\[OAcute]n sobre la m\
\[EAcute]trica (con un Input)",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.67, 0]]
}], "Text",
 CellChangeTimes->{{3.942362542350928*^9, 3.942362568359085*^9}, {
  3.98449584733864*^9, 
  3.9844958759679546`*^9}},ExpressionUUID->"713b74af-0035-274a-a882-\
c88011da1292"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"eleccion", "=", 
    RowBox[{
    "Input", "[", 
     "\"\<Selecciona la M\[EAcute]trica:\\n1 - FLRW (Cosmolog\[IAcute]a)\\n2 \
- Agujero Negro \\n3 - Estrella \>\"", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"G", "=", 
   RowBox[{"Switch", "[", 
    RowBox[{"eleccion", ",", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"OPCI\[CapitalOAcute]N", " ", "1"}], ":", "FLRW"}], " ", 
      "*)"}], "1", ",", 
     RowBox[{
      RowBox[{"Print", "[", "\"\<Has elegido: 1 - FLRW\>\"", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"CTensor", "[", 
       RowBox[{
        RowBox[{"DiagonalMatrix", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "1"}], ",", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"A", "[", 
              RowBox[{"t", "[", "]"}], "]"}], ")"}], "2"], ",", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"A", "[", 
               RowBox[{"t", "[", "]"}], "]"}], ")"}], "2"], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"r", "[", "]"}], ")"}], "2"]}], ",", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"A", "[", 
               RowBox[{"t", "[", "]"}], "]"}], ")"}], "2"], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"r", "[", "]"}], ")"}], "2"], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"Sin", "[", 
               RowBox[{"\[Theta]", "[", "]"}], "]"}], ")"}], "2"]}]}], "}"}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "base"}], ",", 
          RowBox[{"-", "base"}]}], "}"}]}], "]"}]}], ",", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"OPCI\[CapitalOAcute]N", " ", "2"}], ":", 
       RowBox[{"AGUJERO", " ", "NEGRO"}]}], " ", "*)"}], "2", ",", 
     RowBox[{
      RowBox[{"Print", "[", "\"\<Has elegido: 2 - Agujero Negro \>\"", "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"CTensor", "[", 
       RowBox[{
        RowBox[{"DiagonalMatrix", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Q", "[", 
             RowBox[{"r", "[", "]"}], "]"}]}], ",", 
           SuperscriptBox[
            RowBox[{"Q", "[", 
             RowBox[{"r", "[", "]"}], "]"}], 
            RowBox[{"-", "1"}]], ",", " ", 
           RowBox[{
            RowBox[{"r", "[", "]"}], "^", "2"}], ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"r", "[", "]"}], "^", "2"}], 
            RowBox[{
             RowBox[{"Sin", "[", 
              RowBox[{"\[Theta]", "[", "]"}], "]"}], "^", "2"}]}]}], "}"}], 
         "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "base"}], ",", 
          RowBox[{"-", "base"}]}], "}"}]}], "]"}]}], ",", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"OPCI\[CapitalOAcute]N", " ", "3"}], ":", "ESTRELLA"}], " ", 
      "*)"}], "3", ",", 
     RowBox[{
      RowBox[{"Print", "[", "\"\<Has elegido: 3 - Estrella \>\"", "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"CTensor", "[", 
       RowBox[{
        RowBox[{"DiagonalMatrix", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Q", "[", 
             RowBox[{"r", "[", "]"}], "]"}]}], ",", 
           RowBox[{"J", "[", 
            RowBox[{"r", "[", "]"}], "]"}], ",", 
           SuperscriptBox[
            RowBox[{"r", "[", "]"}], "2"], ",", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"r", "[", "]"}], "2"], 
            SuperscriptBox[
             RowBox[{"Sin", "[", 
              RowBox[{"\[Theta]", "[", "]"}], "]"}], "2"]}]}], "}"}], "]"}], 
        ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "base"}], ",", 
          RowBox[{"-", "base"}]}], "}"}]}], "]"}]}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "Caso", " ", "por", " ", "defecto", " ", "si", " ", "escribes", " ", 
       "mal"}], "*)"}], "_", ",", 
     RowBox[{"Abort", "[", "]"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.977575280350603*^9, 3.9775754469061146`*^9}, {
   3.9775759281289024`*^9, 3.97757593233872*^9}, 3.977581043683481*^9, 
   3.978179562668434*^9},
 CellLabel->"In[28]:=",ExpressionUUID->"da9e2672-b8f2-d54c-a029-708f7a3f8fc6"],

Cell[BoxData["\<\"Has elegido: 1 - FLRW\"\>"], "Print",
 CellChangeTimes->{3.977575910543234*^9, 3.9775764811779213`*^9, 
  3.9775802558257933`*^9, 3.9775804308759828`*^9, 3.977581804856898*^9, 
  3.9781786560077724`*^9, 3.9781800390829144`*^9, 3.9781819357760334`*^9, 
  3.978183114860613*^9, 3.978183505911087*^9},
